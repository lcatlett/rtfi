#!/usr/bin/env bash
# Strip common AI/LLM attribution patterns from commit messages.
# Patterns are removed silently — the commit proceeds without them.
#
# Install: git config core.hooksPath .githooks

set -euo pipefail

MSG_FILE="$1"

PATTERNS=(
  'Co-Authored-By:.*[Cc]laude.*'
  'Co-Authored-By:.*[Aa]nthropic.*'
  'Co-Authored-By:.*[Oo]pen[Aa][Ii].*'
  'Co-Authored-By:.*[Cc]opilot.*'
  'Co-Authored-By:.*[Cc]hat[Gg][Pp][Tt].*'
  'Co-Authored-By:.*[Gg]emini.*'
  'Co-Authored-By:.*noreply@anthropic\.com.*'
  '.*Generated with \[Claude Code\].*'
  '.*Generated with \[ChatGPT\].*'
  '.*Generated by AI.*'
)

for pattern in "${PATTERNS[@]}"; do
  sed -i.bak -E "/$pattern/d" "$MSG_FILE"
done

# Remove trailing blank lines left after stripping
sed -i.bak -e :a -e '/^\n*$/{$d;N;ba' -e '}' "$MSG_FILE"
rm -f "${MSG_FILE}.bak"
